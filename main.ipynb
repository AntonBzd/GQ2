import pandas as pd

from marginal_model import fit_all, get_uniform_matrix, summary_table
from factor_copula import fit_static_clusters, select_n_groups, cluster_table
from gas_hmm_factor_copula import fit_gas_hmm_dynamic_clusters, gas_hmm_transition_summary, gas_hmm_cluster_occupancy


prices = pd.read_csv('SP100_tickers_close.csv', index_col=0)

results = fit_all(prices, verbose=True)
print(summary_table(results)) # Appendix C, Table 3, Panel B

U = get_uniform_matrix(results) # Matrice - input direct pour la copula


# Fixer G et voir les groupes
result = fit_static_clusters(U, G=21, n_starts=10, seed=42)
print(cluster_table(result))

# SÃ©lection auto de G par BIC
results = select_n_groups(U, G_range=range(3, 26), n_starts=10)
best_G = min(results, key=lambda g: results[g].bic)
print(cluster_table(results[best_G]))



#### Try but very long to run, check again if follow truely the paper guidelines
gas_hmm_result = fit_gas_hmm_dynamic_clusters(
    U=U,
    static_result=result,
    max_outer_iter=5,
    gas_maxiter=60,
    init_strength=0.98,
    tol_assignments=0.001,
    verbose=True,
)

U_test = U.iloc[:250, :30]

static_test = fit_static_clusters(
    U_test,
    G=5,
    n_starts=3,
    seed=42
)

test_result = fit_gas_hmm_dynamic_clusters(
    U=U_test,
    static_result=static_test,
    max_outer_iter=2,
    gas_maxiter=5,
    init_strength=0.98,
    tol_assignments=0.005,
    verbose=True,
)
